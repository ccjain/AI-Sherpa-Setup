{
  "permissions": {
    "deny": [
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(**/*.p12)",
      "Read(**/*.pfx)",
      "Read(**/secrets/**)",
      "Read(**/credentials/**)",
      "Read(**/.aws/**)",
      "Read(**/.ssh/**)",
      "Read(**/config/database.yml)",
      "Write(**/.env)",
      "Write(**/.env.*)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "node -e \"const cp=require('child_process');try{cp.execSync('crg-daemon status',{stdio:'ignore'})}catch(e){try{const p=cp.spawn('crg-daemon',['start'],{detached:true,stdio:'ignore'});p.unref()}catch(e2){try{cp.execSync('code-review-graph build --quiet',{stdio:'ignore'})}catch(e3){}}}\"",
            "timeout": 60000
          }
        ]
      }
    ]
  }
}
