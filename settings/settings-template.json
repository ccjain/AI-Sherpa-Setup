{
  "permissions": {
    "deny": [
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(**/*.p12)",
      "Read(**/*.pfx)",
      "Read(**/secrets/**)",
      "Read(**/credentials/**)",
      "Read(**/.aws/**)",
      "Read(**/.ssh/**)",
      "Read(**/config/database.yml)",
      "Write(**/.env)",
      "Write(**/.env.*)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "node -e \"const fs=require('fs');if(fs.existsSync('graphify-out/graph.json')){try{require('child_process').execSync('graphify update .',{stdio:'ignore'})}catch(e){}}else{process.stderr.write('[AI Sherpa] No Graphify index for this project. Run /graphify to build one.\\n');process.exit(2)}\"",
            "timeout": 60000
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node -e \"const fs=require('fs');if(fs.existsSync('graphify-out/graph.json')){try{require('child_process').execSync('graphify update .',{stdio:'ignore'})}catch(e){}}\"",
            "timeout": 60000
          }
        ]
      }
    ]
  }
}
