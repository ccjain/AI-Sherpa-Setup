# Added by code-review-graph
.code-review-graph/

# ----------------------------------------------------------------------------
# Editor / IDE local workspace dirs (per-developer, never share)
# ----------------------------------------------------------------------------
.vscode/
.idea/
*.iml
.kiro/
.qoder/
.gemini/
.claude/
# Exception: test fixtures intentionally ship `.claude/` directories as
# inputs to the SessionStart hook test suite. They are not per-developer
# state — they're checked-in fixture trees.
!scripts/fixtures/**/.claude/
!scripts/fixtures/**/.claude/**

# ----------------------------------------------------------------------------
# OS junk
# ----------------------------------------------------------------------------
Thumbs.db
ehthumbs.db
Desktop.ini
desktop.ini
.DS_Store
.AppleDouble
.LSOverride

# ----------------------------------------------------------------------------
# Editor backups / swap files
# ----------------------------------------------------------------------------
*.swp
*.swo
*~
*.bak

# ----------------------------------------------------------------------------
# Logs and ad-hoc session dumps
# ----------------------------------------------------------------------------
*.log
# Dated session/transcript dumps that occasionally land in the repo root
20[0-9][0-9]-[0-1][0-9]-[0-3][0-9]-*.txt

# ----------------------------------------------------------------------------
# Python (for the analyzer-prototype and any tooling installed alongside)
# ----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
env/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# ----------------------------------------------------------------------------
# Node (for any tool that ships node_modules locally)
# ----------------------------------------------------------------------------
node_modules/

# ----------------------------------------------------------------------------
# Local secrets / environment overrides — never commit
# ----------------------------------------------------------------------------
.env
.env.*
!.env.example
*.pem
*.key
